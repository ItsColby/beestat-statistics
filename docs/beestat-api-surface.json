{
  "integration_decisions": [
    {
      "decision": "used",
      "reason": "The integration needs Beestat cloud/history data refreshed before reading native entities or importing Recorder statistics.",
      "surface": "runtime.sync, thermostat.sync, sensor.sync"
    },
    {
      "decision": "used",
      "reason": "These are the narrow metadata reads that support Home Assistant device matching, status sensors, and options-flow discovery.",
      "surface": "thermostat.read_id, sensor.read_id"
    },
    {
      "decision": "used",
      "reason": "Point-history reads are windowed and feed daily Home Assistant external statistics.",
      "surface": "runtime_thermostat.read, runtime_sensor.read"
    },
    {
      "decision": "used",
      "reason": "Summary rows are windowed for normal imports once Home Assistant Recorder has a prior cumulative seed; the importer keeps a full-baseline fallback for new installs, missing seeds, and rebuilds.",
      "surface": "runtime_thermostat_summary.read_id with date attributes"
    },
    {
      "decision": "not_used",
      "reason": "These Beestat comparison/profile features are not local HA state, are cached app analysis paths, and would broaden the integration beyond history import/status enrichment.",
      "surface": "thermostat.get_metrics, thermostat.generate_profile"
    },
    {
      "decision": "used",
      "reason": "When Home Assistant records a filter change, the integration can dismiss matching active Beestat filter alerts so Beestat's alert state follows the local acknowledgement.",
      "surface": "thermostat.dismiss_alert"
    },
    {
      "decision": "not_used",
      "reason": "Restoring alerts and broad thermostat updates would make this statistics integration a general Beestat control surface. Direct filter metadata updates are also avoided because Beestat sync owns that field and can overwrite local writes.",
      "surface": "thermostat.restore_alert, thermostat.update"
    }
  ],
